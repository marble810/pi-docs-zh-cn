{
  "name": "pi-docs-zh-cn",
  "version": "0.0.1",
  "private": true,
  "description": "Pi 简体中文文档社区翻译站点",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "pnpm generate:site && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "sync:check": "tsx scripts/cli.ts check",
    "sync:run": "tsx scripts/cli.ts sync",
    "sync:force": "tsx scripts/cli.ts sync --force",
    "translate:resume": "tsx scripts/cli.ts resume",
    "generate:site": "tsx scripts/generate-site-data.ts",
    "validate:content": "tsx scripts/validate-content.ts",
    "security:scan": "tsx scripts/scan-secrets.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.52.0",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.25.5",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/hast": "^3.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.15.23",
    "bits-ui": "^1.4.8",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-svelte": "^3.7.0",
    "globals": "^16.1.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "minisearch": "^7.1.4",
    "opencc-js": "^1.0.5",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.4.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "shiki": "^3.4.0",
    "svelte": "^5.28.2",
    "svelte-check": "^4.2.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.0",
    "zod": "^3.25.59"
  }
}
