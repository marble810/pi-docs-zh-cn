# DeepSeek API - 仅用于翻译步骤，不要提交到仓库
DEEPSEEK_API_KEY=

# DeepSeek 配置 (defaults work for most cases)
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# 可选配置
DEEPSEEK_REQUEST_TIMEOUT_MS=300000
DEEPSEEK_MAX_REQUESTS_PER_RUN=1000
DEEPSEEK_MAX_MODEL_ATTEMPTS=6

# 站点 base path（GitHub Pages 默认 /<repo-name>/）
BASE_PATH=/pi-docs-zh-cn
