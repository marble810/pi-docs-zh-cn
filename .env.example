# OpenRouter API Key - 仅用于翻译步骤，不要提交到仓库
OPENROUTER_API_KEY=

# OpenRouter 配置
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://github.com/earendil-works/pi-docs-zh-cn
OPENROUTER_APP_NAME=Pi Simplified Chinese Docs
OPENROUTER_MAX_REQUESTS_PER_RUN=35

# 站点 base path（GitHub Pages 默认 /<repo-name>/）
BASE_PATH=/pi-docs-zh-cn
