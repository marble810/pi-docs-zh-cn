# NVIDIA NIM API - 仅用于翻译步骤，不要提交到仓库
AI_PROVIDER=nvidia
NVIDIA_API_KEY=

# NVIDIA 配置 (defaults work for most cases)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_CHAIN=deepseek-ai/deepseek-v4-pro,deepseek-ai/deepseek-v4-flash,nvidia/riva-translate-4b-instruct-v1_1

# 可选配置
NVIDIA_REQUEST_TIMEOUT_MS=300000
NVIDIA_POLL_TIMEOUT_MS=180000
NVIDIA_MAX_REQUESTS_PER_RUN=100
NVIDIA_REQUESTS_PER_MINUTE=10
NVIDIA_MAX_MODEL_ATTEMPTS=1
NVIDIA_CHECK_MODEL_AVAILABILITY=true

# 站点 base path（GitHub Pages 默认 /<repo-name>/）
BASE_PATH=/pi-docs-zh-cn
